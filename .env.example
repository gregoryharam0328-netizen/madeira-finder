# Shared
APP_NAME=Madeira Property Finder
APP_ENV=development
APP_TIMEZONE=Europe/Lisbon
# Local wall time (in APP_TIMEZONE) for automatic daily ingestion. Default 05:00.
DAILY_INGESTION_LOCAL_HOUR=5
DAILY_INGESTION_LOCAL_MINUTE=0
# If true, API startup runs daily scrape when today's scheduled success is still missing (e.g. server started after the daily slot).
ENABLE_STARTUP_DAILY_CATCHUP=true
# If true, while uvicorn stays up the API runs ingestion every day at DAILY_INGESTION_LOCAL_HOUR:MINUTE.
# Set false if you run daily_runner from cron/systemd instead.
ENABLE_DAILY_SCHEDULER=true

# Backend
# For Supabase Postgres (Transaction Pooler), use port 6543 + sslmode=require:
# DATABASE_URL=postgresql+psycopg://postgres.<project_ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.aatguughfujygezjyorq:BdgHtaCfDNQptg2o@aws-1-us-east-1.pooler.supabase.com:6543/postgres
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
BACKEND_CORS_ORIGINS=http://localhost:3000

# Digest
RESEND_API_KEY=
DIGEST_FROM_EMAIL=info@exploringmadeira.com
DIGEST_TO_EMAILS=info@exploringmadeira.com

# Scraping / ingestion (required for real Idealista data)
# Get a token at https://console.apify.com/ — without it Idealista returns zero rows.
APIFY_TOKEN=
# Apify actor id for REST: `username~actor-name` (see https://apify.com/igolaizola/idealista-scraper)
IDEALISTA_APIFY_ACTOR_ID=igolaizola~idealista-scraper
# Extra Idealista tabs (slow / many requests): true|false
IDEALISTA_APIFY_FETCH_DETAILS=false
IDEALISTA_APIFY_FETCH_STATS=false
APIFY_ACTOR_TIMEOUT_SECONDS=300

# Optional: import Idealista rows from a public dataset file (CSV / JSONL / JSON) without Apify at scrape time.
# Use a Google Drive direct link or a share URL (the app rewrites .../file/d/<id>/view to uc?export=download&id=<id>).
# Example share: https://drive.google.com/file/d/1UQQLoQjcEuoYenA_FzOF3FukglH3EmWU/view
IDEALISTA_CSV_IMPORT_URL=
IDEALISTA_CSV_IMPORT_MAX_ROWS=5000
# If true, import once when the API process starts (daily ingestion also runs this when IDEALISTA_CSV_IMPORT_URL is set).
IDEALISTA_CSV_IMPORT_ON_STARTUP=false

# Client filters (optional overrides)
MIN_PRICE_GBP=250000
MAX_PRICE_GBP=350000
GBP_TO_EUR_RATE=1.17
MIN_BEDROOMS=2
ALLOWED_PROPERTY_TYPES_CSV=house,apartment,villa,land
IDEALISTA_LOCATION_CODE=0-EU-PT-31

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
